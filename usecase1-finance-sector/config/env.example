# Finance Sector Use Case — Environment Configuration
# Copy this file and fill in your values:
#   cp env.example .env

# === Control Plane ===
GRAPH_OLAP_API_URL=https://<your-control-plane-url>
GRAPH_OLAP_USE_CASE_ID=<your-use-case-id>
GRAPH_OLAP_IN_CLUSTER_MODE=true
GRAPH_OLAP_VERIFY_SSL=false
GRAPH_OLAP_SKIP_HEALTH_CHECK=true

# === Proxy (if behind corporate proxy) ===
# Remove or leave empty if no proxy needed
https_proxy=http://<proxy-host>:<port>
http_proxy=http://<proxy-host>:<port>

# === Starburst / Trino ===
STARBURST_CATALOG=<your-catalog>
STARBURST_SCHEMA=<your-schema>
STARBURST_USER=<your-service-account>
STARBURST_PASSWORD=<your-password>
STARBURST_TRINO_URL=https://<your-trino-endpoint>

# === Auth (JWT/OIDC) ===
AUTH0_JWKS_URL=https://<your-auth-domain>/.well-known/jwks.json
AUTH0_AUDIENCE=<your-api-audience>
AUTH0_ISSUER=https://<your-auth-domain>/
AUTH0_EMAIL_CLAIM=https://api.graph-olap.example.com/email
AUTH0_ROLES_CLAIM=https://api.graph-olap.example.com/roles

# === GCS ===
GCP_PROJECT=<your-gcp-project>
GCS_BUCKET=<your-gcs-bucket>

# === Database ===
GRAPH_OLAP_DATABASE_URL=postgresql://<user>:<pass>@<host>:5432/control_plane
