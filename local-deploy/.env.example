# Graph OLAP Local Deployment — Environment Variables
# Copy to .env and fill in your values, then: source .env

# ------------------------------------------------------------------
# Required: Path to the graph-olap monorepo (source code).
# Default is ../graph-olap (if both repos are siblings).
# ------------------------------------------------------------------
# export MONOREPO_ROOT=../graph-olap

# ------------------------------------------------------------------
# Starburst Galaxy credentials.
# Without these, the core API starts but export jobs will fail.
# Create a service account in Galaxy UI: Settings → Service Accounts
# Update helm/values-local.yaml starburst.url and starburst.user too.
# ------------------------------------------------------------------
# export STARBURST_USER=your-service-account@your-org/accountadmin
# export STARBURST_PASSWORD=your-galaxy-password

# ------------------------------------------------------------------
# Google Cloud Storage access.
# Without this, a placeholder empty secret is created automatically
# and snapshot/export operations that use GCS will fail.
# Update helm/values-local.yaml gcpProject and gcs.bucket too.
# ------------------------------------------------------------------
# export GCP_SA_KEY_JSON=$(cat /path/to/sa-key.json)
